{
  "manifest_version": 3,
  "name": "Ghost Interface",
  "version": "0.1.1",
  "description": "AI-powered ATS form autofill with per-field confidence scoring. Fills smarter, not faster.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://*.myworkdayjobs.com/*",
    "https://jobs.lever.co/*",
    "https://*.icims.com/*",
    "https://*.bamboohr.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.app.loxo.co/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://*.myworkdayjobs.com/*",
        "https://jobs.lever.co/*",
        "https://*.icims.com/*",
        "https://*.bamboohr.com/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.app.loxo.co/*"
      ],
      "js": ["src/content/index.ts"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Ghost Interface",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
